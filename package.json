{
  "name": "deepseek-loop-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Durable state-graph agent runtime for compiler-driven COBOL-to-Java migration",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "tsx src/apps/cli/main.ts migrate-one",
    "migrate-batch": "tsx src/apps/cli/main.ts migrate-batch",
    "migrate-program": "tsx src/apps/cli/main.ts migrate-program",
    "migrate-program-spring": "tsx src/apps/cli/main.ts migrate-program-spring",
    "migrate-program-meta": "tsx src/apps/cli/main.ts migrate-program-meta"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "dotenv": "^16.4.7",
    "execa": "^9.5.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
